# Terraform state — bootstrap uses local state; never commit it
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform directories
.terraform/
.terraform.lock.hcl

# Sensitive variable files — keep your tfvars local
*.tfvars
!terraform.tfvars  # terraform.tfvars is committed as the example/default values

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
